GOOGLE_CLIENT_SECRET_FILE=client_secret.json
HEALTHEX_TOKEN_FILE=token.json

# --- choose one DATABASE_URL ---

# Local docker-compose Postgres (offline tests / CI):
DATABASE_URL=postgresql+psycopg://healthex:healthex@localhost:5432/healthex

# Homelab Postgres via Traefik TCP LoadBalancer (real persistent store + Grafana):
# DATABASE_URL=postgresql+psycopg://healthex:<pw>@<traefik-lb-ip>:5432/healthex
